# Scion Chat App Environment Configuration
# Copy this file to /home/scion/.scion/chat-app.env and fill in your values.
# The install script sources both this file and hub.env to generate the
# runtime config and patch system files.

# === Required ===

# GCP project ID where the Google Chat app is registered
CHAT_APP_PROJECT_ID=my-scion-chat

# Path to the service account key file for Google Chat API calls.
# This SA needs the Chat API permissions described in the README.
CHAT_APP_CREDENTIALS=/home/scion/.scion/chat-sa-key.json

# Service account email shown on the Chat API configuration page.
# Used for verifying inbound request tokens.
CHAT_APP_SERVICE_ACCOUNT_EMAIL=

# Hub admin user email that the chat app authenticates as.
CHAT_APP_HUB_USER=chat-app@example.com

# === Optional ===

# Path to a file containing a Hub bearer token for the admin user.
# If empty, the chat app will attempt device authorization on first start.
# CHAT_APP_HUB_CREDENTIALS=/home/scion/.scion/chat-app-token

# Override the listen port for the Google Chat event endpoint (default: 8443).
# CHAT_APP_LISTEN_PORT=8443
